    "competitive_feature_targets": [
      "P0 grouped code-query results by process, module, evidence path, source span, freshness, and ranking explanation.",
      "P0 web code-graph workspace with graph canvas, file tree, code references, process list, query/chat state, and shareable selections.",
      "P0 unified SSE progress and cancellation for repository indexing, semantic/vector refresh, local-file indexing, and worker proposals.",
      "P1 route, tool, and shape derived indexes for API, MCP, RPC, CLI, GraphQL, and event consumer impact analysis.",
      "P1 MCP and agent contracts with intent fields for goal, task context, max symbols, content inclusion, freshness policy, and audit context.",
      "P1 source groups and cross-repository contract read models that expose stale, version, provider, consumer, and confidence states.",
      "P1 chat grounding and citations bound to context-pack provenance, graph/index versions, source spans, and freshness indicators.",
      "P2 server-side or cached graph layout and scope lenses for large graph navigation without blocking query hot paths.",
      "P2 read-only rename or refactor proposals with confidence, affected references, suggested tests, and explicit approval before writes."
    ],
    "implementation_guardrails": [
      "Do not improve a case by enumerating known queries, paths, repositories, symbols, routes, or fixture-specific strings.",
      "Keep env, paths, net, HTTP, and QoS ownership boundaries intact; runtime state must not default to repository-local paths.",
      "Keep query hot paths async and bounded; heavy layout, extraction, embedding, indexing, and rebuild work must run behind worker or maintenance boundaries.",
      "Tie retrieval, context packs, citations, and UI views to explicit graph/index freshness, versions, and source spans.",
      "Update deterministic cases, research judge evidence, and user or maintainer documentation in the same change set."
    ],
    "rubric_dimensions": [
