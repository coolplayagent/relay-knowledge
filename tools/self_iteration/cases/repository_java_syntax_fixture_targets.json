      "limit": 12,
      "max_rank": 8,
      "language_filters": ["java"],
      "expected": [{"path": "src/main/java/example/ServiceFactory.java", "excerpt_contains": "create().handle(value)"}],
      "expected_sequence": [
        {"path": "src/main/java/example/ServiceFactory.java", "excerpt_contains": "create().handle(value)"},
        {"path": "src/main/java/example/AnnotatedService.java", "excerpt_contains": "normalize(value).trim()"}
