      "limit": 10,
      "max_rank": 3,
      "language_filters": ["java"],
      "expected": [{"path": "src/main/java/example/AnnotatedService.java", "excerpt_contains": "public String handle"}],
      "case_group": "java_tree_sitter_syntax"
