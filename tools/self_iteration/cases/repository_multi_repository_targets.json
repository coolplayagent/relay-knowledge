      "query": "client.Dial envconfig MustLoadDefaultClientOptions workflow client",
      "objective": "competitive_capability",
      "limit": 10,
      "max_rank": 5,
      "language_filters": [
        "go"
      ],
      "expected": [
        {
          "repository_alias": "temporal-samples-go-self-iteration",
          "path": "helloworld/worker/main.go",
          "excerpt_contains": "client.Dial"
        }
      ],
      "case_group": "multi_repository",
      "min_score": 0.45,
      "require_expected_all": false,
      "forbidden_rank_penalty": 0.08,
      "expected_all": [
        {
          "repository_alias": "temporal-samples-go-self-iteration",
          "path": "helloworld/worker/main.go",
          "excerpt_contains": "client.Dial"
        },
        {
          "repository_alias": "temporal-sdk-go-self-iteration",
          "path": "client/client.go",
          "excerpt_contains": "func Dial"
        }
      ]
